---
import { getCollection } from 'astro:content';

interface Props {
	title?: string;
	description?: string;
	/** Bỏ max-width để hero / landing full-bleed */
	wideMain?: boolean;
}

const {
	title = 'My Astro App',
	description = 'Blog & pages powered by Astro + Keystatic',
	wideMain = false,
} = Astro.props;
const currentPath = Astro.url.pathname;

const coreNav = [{ href: '/keystatic', label: 'Quản trị' }];

const reservedPageSlugs = new Set(['blog', 'keystatic', 'api', '_astro']);

const dynamicPageNav = (await getCollection('pages'))
	.filter((page) => !reservedPageSlugs.has(page.id.toLowerCase()))
	.filter((page) => page.data.showInHeader !== false)
	.sort((a, b) => (a.data.navOrder ?? 100) - (b.data.navOrder ?? 100))
	.map((page) => ({
		href: `/${page.id}`,
		label: page.data.navLabel?.trim() || page.data.title,
	}));

const systemNav = (await getCollection('sitePages'))
	.filter((entry) => ['home', 'blog'].includes(entry.id.toLowerCase()))
	.filter((entry) => entry.data.showInHeader !== false)
	.sort((a, b) => (a.data.navOrder ?? 10) - (b.data.navOrder ?? 10))
	.map((entry) => ({
		href: entry.id.toLowerCase() === 'home' ? '/' : '/blog',
		label: entry.data.navLabel?.trim() || entry.data.pageTitle,
	}));

const nav = [...systemNav, ...dynamicPageNav, ...coreNav];
---

<!doctype html>
<html lang="vi">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="logo" href="/">AstroBlog</a>
			<nav class="nav" aria-label="Chính">
				{nav.map(({ href, label }) => {
					const isActive =
						href === '/'
							? currentPath === '/'
							: currentPath === href || currentPath.startsWith(`${href}/`);

					return (
						<a href={href} aria-current={isActive ? 'page' : undefined}>
							{label}
						</a>
					);
				})}
			</nav>
			<a class="nav-cta" href="/blog">Xem bài viết</a>
		</header>
		<main class:list={['main', wideMain && 'main--wide']}>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--primary: #2563eb;
		--primary-600: #1d4ed8;
		--primary-soft: #dbeafe;
		--accent-cyan: #06b6d4;
		--bg-page: #f8fafc;
		--bg-base: #ffffff;
		--surface-1: #ffffff;
		--surface-2: #f1f5f9;
		--text-1: #0f172a;
		--text-2: #334155;
		--text-3: #64748b;
		--text-heading: var(--text-1);
		--muted: var(--text-3);
		--border-1: #e2e8f0;
		--border-2: #cbd5e1;
		--radius-sm: 10px;
		--radius-md: 14px;
		--radius-lg: 18px;
		--space-2: 0.5rem;
		--space-3: 0.75rem;
		--space-4: 1rem;
		--space-6: 1.5rem;
		--space-8: 2rem;
		--space-12: 3rem;
		--shadow-sm: 0 4px 14px rgba(15, 23, 42, 0.06);
		--shadow-md: 0 10px 30px rgba(15, 23, 42, 0.08);
		--content-width: min(100% - 2rem, 72rem);
		--reading-width: 72ch;
		font-family: 'Inter', system-ui, 'Segoe UI', Roboto, sans-serif;
		line-height: 1.6;
		color: var(--text-2);
		background: var(--bg-page);
		-webkit-font-smoothing: antialiased;
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: var(--space-4);
		padding: 0.85rem 1rem;
		max-width: var(--content-width);
		margin: 0 auto;
		background: color-mix(in srgb, var(--bg-base) 92%, transparent);
		border: 1px solid var(--border-1);
		border-radius: var(--radius-lg);
		position: sticky;
		top: 0.75rem;
		z-index: 40;
		backdrop-filter: blur(10px);
		margin-top: 0.75rem;
	}

	.logo {
		font-weight: 700;
		font-size: 1.125rem;
		color: var(--primary);
		text-decoration: none;
		letter-spacing: -0.02em;
	}

	.logo:hover {
		color: var(--primary-600);
	}

	.nav {
		display: flex;
		gap: 0.25rem 1.25rem;
		flex-wrap: wrap;
		justify-content: flex-end;
		flex: 1;
	}

	.nav a {
		color: var(--text-3);
		text-decoration: none;
		font-size: 0.9375rem;
		font-weight: 500;
		padding: 0.35rem 0.625rem;
		border-radius: 999px;
		transition:
			color 0.15s ease,
			background 0.15s ease;
	}

	.nav a:hover {
		color: var(--primary-600);
		background: var(--surface-2);
	}

	.nav a[aria-current='page'] {
		color: var(--primary-600);
		background: var(--primary-soft);
	}

	.nav-cta {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 1rem;
		background: var(--bg-base);
		color: var(--primary);
		font-size: 0.875rem;
		font-weight: 600;
		text-decoration: none;
		border-radius: 999px;
		border: 1px solid var(--primary);
		white-space: nowrap;
		transition:
			background 0.15s ease,
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.nav-cta:hover {
		background: var(--primary);
		color: white;
		border-color: var(--primary);
	}

	.main {
		max-width: var(--reading-width);
		margin: 0 auto;
		padding: var(--space-8) 1rem var(--space-12);
	}

	.main--wide {
		max-width: none;
		margin: 0;
		padding: 0;
	}

	.prose {
		font-size: 1.05rem;
		color: var(--text-2);
		line-height: 1.78;
	}

	.prose h1 {
		margin: 0 0 0.75em;
		font-size: clamp(1.9rem, 3vw, 2.35rem);
		line-height: 1.15;
		letter-spacing: -0.03em;
		color: var(--text-1);
	}

	.prose h2 {
		margin-top: 1.8em;
		margin-bottom: 0.55em;
		font-size: clamp(1.35rem, 2.2vw, 1.7rem);
		line-height: 1.2;
		letter-spacing: -0.02em;
		color: var(--text-1);
	}

	.prose h3 {
		margin-top: 1.35em;
		margin-bottom: 0.45em;
		font-size: 1.15rem;
		line-height: 1.35;
		color: var(--text-1);
	}

	.prose p {
		margin: 0.75em 0;
		color: var(--text-2);
	}

	.prose ul,
	.prose ol {
		padding-left: 1.2rem;
	}

	.prose li {
		margin: 0.45em 0;
	}

	.prose blockquote {
		margin: 1.5rem 0;
		padding: 0.75rem 1rem;
		border-left: 3px solid var(--primary);
		background: var(--surface-2);
		border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
		color: var(--text-2);
	}

	.prose pre {
		padding: 1rem;
		background: #0b1220;
		color: #e2e8f0;
		border-radius: var(--radius-sm);
		overflow: auto;
	}

	.prose code {
		font-size: 0.9em;
		border-radius: 6px;
	}

	.prose img {
		max-width: 100%;
		height: auto;
		border-radius: var(--radius-md);
	}

	.prose a {
		color: var(--primary);
		font-weight: 500;
	}

	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.post-list li {
		padding: 1rem 0;
		border-bottom: 1px solid var(--border-1);
	}

	.post-list a {
		color: var(--primary);
		font-size: 1.125rem;
		font-weight: 600;
		text-decoration: none;
	}

	.post-list a:hover {
		text-decoration: underline;
	}

	.meta {
		color: var(--text-3);
		font-size: 0.9rem;
		margin: 0.35rem 0 0;
	}

	a:focus-visible {
		outline: 2px solid var(--accent-cyan);
		outline-offset: 2px;
		border-radius: 6px;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
		background: var(--bg-page);
	}
</style>
