# ============================================
# Keystatic Configuration
# ============================================

# Storage mode for Keystatic (OPTIONAL - auto-detected):
# - If not set:
#   * Production (Cloudflare Workers): automatically uses 'github'
#   * Development (local): automatically uses 'local'
# - Explicit override: uncomment and set to 'local' or 'github'
# KEYSTATIC_STORAGE_KIND=local

# ============================================
# GitHub Mode Configuration
# (Required for production, optional for dev)
# ============================================

# GitHub repository for content storage
# Format: owner/repo
# Example: jeunet0nas/astro-workers
KEYSTATIC_GITHUB_REPO=your-username/your-repo

# Optional: branch prefix filter for Keystatic UI
# Example: content/
# KEYSTATIC_GITHUB_BRANCH_PREFIX=

# ---------- GitHub App Credentials ----------
# Create GitHub App at: https://github.com/settings/apps
# Required permissions:
#   - Repository contents: Read & Write
#   - Repository metadata: Read-only
# Callback URL: https://your-site.com/api/keystatic/github/oauth/callback

# GitHub OAuth Client ID
KEYSTATIC_GITHUB_CLIENT_ID=your_client_id_here

# GitHub OAuth Client Secret
KEYSTATIC_GITHUB_CLIENT_SECRET=your_client_secret_here

# Keystatic secret for session/auth (min 32 chars)
# Generate with: openssl rand -hex 32
KEYSTATIC_SECRET=your_random_secret_here

# GitHub App slug (from App settings)
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=your-app-slug

# ============================================
# Production Deployment Notes
# ============================================
# For Cloudflare Workers, set environment variables via:
#   wrangler secret put KEYSTATIC_GITHUB_CLIENT_ID
#   wrangler secret put KEYSTATIC_GITHUB_CLIENT_SECRET
#   wrangler secret put KEYSTATIC_SECRET
#   wrangler secret put PUBLIC_KEYSTATIC_GITHUB_APP_SLUG
#   wrangler secret put KEYSTATIC_GITHUB_REPO
#
# See DEPLOYMENT.md (to be created) for detailed instructions.
