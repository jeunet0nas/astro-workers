# Storage mode for Keystatic:
# - local  : edit content files directly on your machine (recommended for local dev)
# - github : use GitHub OAuth + GitHub App (required for production /keystatic editing)
KEYSTATIC_STORAGE_KIND=local

# GitHub repository used when KEYSTATIC_STORAGE_KIND=github
# Format: owner/repo
KEYSTATIC_GITHUB_REPO=your-username/your-repo

# Optional: only allow branches with this prefix in Keystatic UI
# Example: content/
KEYSTATIC_GITHUB_BRANCH_PREFIX=

# ---------- Required only for GitHub mode ----------
# GitHub OAuth Client ID from your GitHub App
# Create at: https://github.com/settings/apps
KEYSTATIC_GITHUB_CLIENT_ID=your_client_id_here

# GitHub OAuth Client Secret from your GitHub App
KEYSTATIC_GITHUB_CLIENT_SECRET=your_client_secret_here

# Random strong secret used by Keystatic auth/session flow
# Generate with: openssl rand -hex 32
KEYSTATIC_SECRET=your_random_secret_here

# Public GitHub App slug (safe to expose, but keep in env for consistency)
# Example: my-keystatic-app
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=your-app-slug
