---
import { getCollection } from 'astro:content';

interface Props {
	title?: string;
	description?: string;
	/** Bỏ max-width để hero / landing full-bleed */
	wideMain?: boolean;
}

const {
	title = 'My Astro App',
	description = 'Blog & pages powered by Astro + Keystatic',
	wideMain = false,
} = Astro.props;

const coreNav = [{ href: '/keystatic', label: 'Quản trị' }];

const reservedPageSlugs = new Set(['blog', 'keystatic', 'api', '_astro']);

const dynamicPageNav = (await getCollection('pages'))
	.filter((page) => !reservedPageSlugs.has(page.id.toLowerCase()))
	.filter((page) => page.data.showInHeader !== false)
	.sort((a, b) => (a.data.navOrder ?? 100) - (b.data.navOrder ?? 100))
	.map((page) => ({
		href: `/${page.id}`,
		label: page.data.navLabel?.trim() || page.data.title,
	}));

const systemNav = (await getCollection('sitePages'))
	.filter((entry) => ['home', 'blog'].includes(entry.id.toLowerCase()))
	.filter((entry) => entry.data.showInHeader !== false)
	.sort((a, b) => (a.data.navOrder ?? 10) - (b.data.navOrder ?? 10))
	.map((entry) => ({
		href: entry.id.toLowerCase() === 'home' ? '/' : '/blog',
		label: entry.data.navLabel?.trim() || entry.data.pageTitle,
	}));

const nav = [...systemNav, ...dynamicPageNav, ...coreNav];
---

<!doctype html>
<html lang="vi">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="logo" href="/">AstroBlog</a>
			<nav class="nav" aria-label="Chính">
				{nav.map(({ href, label }) => <a href={href}>{label}</a>)}
			</nav>
			<a class="nav-cta" href="/blog">Xem bài viết</a>
		</header>
		<main class:list={['main', wideMain && 'main--wide']}>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--color-hero: #0ea5e9;
		--color-hero-deep: #0284c7;
		--bg: #ffffff;
		--surface: #f8fafc;
		--text: #1e293b;
		--text-heading: #0f172a;
		--muted: #64748b;
		--accent: #0284c7;
		--accent-hover: #0369a1;
		--link: #0ea5e9;
		--border: #e2e8f0;
		--shadow-soft: 0 4px 24px rgba(15, 23, 42, 0.06);
		font-family: 'Inter', system-ui, 'Segoe UI', Roboto, sans-serif;
		line-height: 1.6;
		color: var(--text);
		background: var(--bg);
		-webkit-font-smoothing: antialiased;
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
		padding: 1rem 1.5rem;
		max-width: 72rem;
		margin: 0 auto;
		background: var(--bg);
		border-bottom: 1px solid var(--border);
	}

	.logo {
		font-weight: 700;
		font-size: 1.125rem;
		color: var(--accent);
		text-decoration: none;
		letter-spacing: -0.02em;
	}

	.logo:hover {
		color: var(--accent-hover);
	}

	.nav {
		display: flex;
		gap: 0.25rem 1.25rem;
		flex-wrap: wrap;
		justify-content: flex-end;
		flex: 1;
	}

	.nav a {
		color: var(--muted);
		text-decoration: none;
		font-size: 0.9375rem;
		font-weight: 500;
	}

	.nav a:hover {
		color: var(--accent);
	}

	.nav-cta {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 1.15rem;
		background: var(--bg);
		color: var(--accent);
		font-size: 0.875rem;
		font-weight: 600;
		text-decoration: none;
		border-radius: 999px;
		border: 2px solid var(--accent);
		white-space: nowrap;
		transition:
			background 0.15s ease,
			color 0.15s ease;
	}

	.nav-cta:hover {
		background: var(--accent);
		color: white;
	}

	.main {
		max-width: 42rem;
		margin: 0 auto;
		padding: 2rem 1.25rem 4rem;
	}

	.main--wide {
		max-width: none;
		margin: 0;
		padding: 0;
	}

	.prose {
		font-size: 1.0625rem;
		color: var(--text);
	}

	.prose h1,
	.prose h2 {
		line-height: 1.25;
		margin-top: 1.75em;
		margin-bottom: 0.5em;
		color: var(--text-heading);
	}

	.prose p {
		margin: 0.75em 0;
		color: var(--text);
	}

	.prose img {
		max-width: 100%;
		height: auto;
		border-radius: 8px;
	}

	.prose a {
		color: var(--link);
		font-weight: 500;
	}

	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.post-list li {
		padding: 1rem 0;
		border-bottom: 1px solid var(--border);
	}

	.post-list a {
		color: var(--accent);
		font-size: 1.125rem;
		font-weight: 600;
		text-decoration: none;
	}

	.post-list a:hover {
		text-decoration: underline;
	}

	.meta {
		color: var(--muted);
		font-size: 0.9rem;
		margin: 0.35rem 0 0;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
	}
</style>
