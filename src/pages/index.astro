---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';

const home = await getEntry('sitePages', 'home');
const { Content } = home ? await render(home) : { Content: null };

const pageTitle = home?.data.pageTitle ?? 'Trang chủ';
const pageDescription =
	home?.data.pageDescription ??
	'Blog và nội dung tĩnh với Astro + Keystatic — giao diện sáng, chuyên nghiệp.';
const heroTitle = home?.data.heroTitle ?? 'Welcome';
const heroLead =
	home?.data.heroLead ??
	'Astroblog = Astro + Keystatic';
const primaryCtaLabel = home?.data.primaryCtaLabel ?? 'Khám phá blog';
const primaryCtaHref = home?.data.primaryCtaHref ?? '/blog';
const secondaryCtaLabel = home?.data.secondaryCtaLabel ?? 'Giới thiệu';
const secondaryCtaHref = home?.data.secondaryCtaHref ?? '/about';
const posts = await getCollection('posts', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const latestPosts = posts.slice(0, 3);
const topicCounts = new Map<string, number>();
for (const post of posts) {
	for (const tag of post.data.tags ?? []) {
		topicCounts.set(tag, (topicCounts.get(tag) ?? 0) + 1);
	}
}
const trendingTopics = [...topicCounts.entries()]
	.sort((a, b) => b[1] - a[1])
	.slice(0, 6);
---

<Layout
	title={pageTitle}
	description={pageDescription}
	wideMain
>
	<section class="hero" aria-label="Giới thiệu">
		<div class="hero-inner">
			<p class="hero-breadcrumb"><a href="/">Trang chủ</a></p>
			<h1 class="hero-title">{heroTitle}</h1>
			<p class="hero-lead">{heroLead}</p>
			<div class="hero-actions">
				<a class="btn btn--light" href={primaryCtaHref}>{primaryCtaLabel}</a>
				<a class="btn btn--ghost" href={secondaryCtaHref}>{secondaryCtaLabel}</a>
			</div>
			<ul class="hero-stack" aria-label="Công nghệ sử dụng">
				<li>Astro 6</li>
				<li>Keystatic CMS</li>
				<li>Cloudflare Workers</li>
			</ul>
		</div>
	</section>

	<div class="page-body">
		<section class="section panel" aria-labelledby="section-explore">
			{Content ? (
				<article class="prose">
					<Content />
				</article>
			) : (
				<>
					<h2 id="section-explore" class="section-title">Cách làm việc với site này</h2>
					<p class="section-text">
						Nội dung bài viết và trang tĩnh nằm trong repo dưới dạng file Markdoc. Khi phát triển, mở
						Keystatic để thêm hoặc sửa bài.
					</p>
				</>
			)}
			<ul class="link-grid">
				<li>
					<a href="/blog" class="tile-link">
						<span class="tile-link-title">Blog</span>
						<span class="tile-link-desc">Danh sách bài viết mới nhất</span>
					</a>
				</li>
				<li>
					<a href="/keystatic" class="tile-link">
						<span class="tile-link-title">Keystatic</span>
						<span class="tile-link-desc">Chỉnh nội dung khi chạy dev</span>
					</a>
				</li>
			</ul>
		</section>

		{latestPosts.length > 0 && (
			<section class="section panel" aria-labelledby="latest-posts">
				<h2 id="latest-posts" class="section-title">Bài viết mới nhất</h2>
				<ul class="latest-grid">
					{latestPosts.map((post) => (
						<li>
							<a href={`/blog/${post.id}`} class="latest-card">
								<span class="latest-card-title">{post.data.title}</span>
								<span class="latest-card-meta">
									{post.data.category ?? 'Blog'} · {post.data.publishDate.toLocaleDateString('vi-VN')}
								</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		)}

		{trendingTopics.length > 0 && (
			<section class="section panel" aria-labelledby="trending-topics">
				<h2 id="trending-topics" class="section-title">Chủ đề nổi bật</h2>
				<div class="topic-row">
					{trendingTopics.map(([topic, count]) => (
						<a href="/blog" class="topic-chip">
							#{topic} <span>{count}</span>
						</a>
					))}
				</div>
			</section>
		)}
	</div>
</Layout>

<style>
	.hero {
		background:
			radial-gradient(circle at top right, color-mix(in srgb, var(--accent-cyan) 25%, transparent) 0%, transparent 45%),
			linear-gradient(135deg, color-mix(in srgb, var(--primary) 90%, #0f172a) 0%, #0f172a 100%);
		color: #f8fafc;
		padding: 2.5rem 1.5rem 3.5rem;
		box-shadow: var(--shadow-md);
	}

	.hero-inner {
		max-width: 42rem;
		margin: 0 auto;
	}

	.hero-breadcrumb {
		margin: 0 0 1rem;
		font-size: 0.875rem;
		opacity: 0.92;
	}

	.hero-breadcrumb a {
		color: #e2e8f0;
		text-decoration: none;
		font-weight: 500;
	}

	.hero-breadcrumb a:hover {
		text-decoration: underline;
	}

	.hero-title {
		margin: 0;
		font-size: clamp(1.85rem, 5vw, 2.5rem);
		font-weight: 700;
		line-height: 1.15;
		letter-spacing: -0.03em;
	}

	.hero-lead {
		margin: 1.25rem 0 0;
		font-size: 1.0625rem;
		line-height: 1.65;
		opacity: 0.95;
		max-width: 36rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.75rem;
	}

	.hero-stack {
		margin: 1.15rem 0 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.hero-stack li {
		padding: 0.25rem 0.6rem;
		border: 1px solid rgba(148, 163, 184, 0.45);
		border-radius: 999px;
		font-size: 0.82rem;
		color: #e2e8f0;
		background: rgba(15, 23, 42, 0.25);
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1.35rem;
		font-size: 0.9375rem;
		font-weight: 600;
		font-family: inherit;
		border-radius: 999px;
		text-decoration: none;
		transition:
			background 0.15s ease,
			color 0.15s ease,
			box-shadow 0.15s ease;
	}

	.btn--light {
		background: white;
		color: var(--primary-600);
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
	}

	.btn--light:hover {
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.14);
	}

	.btn--ghost {
		background: transparent;
		color: white;
		border: 2px solid rgba(255, 255, 255, 0.85);
	}

	.btn--ghost:hover {
		background: rgba(255, 255, 255, 0.15);
	}

	.page-body {
		background: var(--bg-page);
		padding: 2.5rem 1.25rem 4rem;
	}

	.section {
		max-width: 42rem;
		margin: 0 auto;
	}

	.panel {
		padding: 2rem 0 0;
	}

	.section-title {
		margin: 0 0 1rem;
		font-size: clamp(1.35rem, 3vw, 1.65rem);
		font-weight: 700;
		color: var(--text-heading);
		letter-spacing: -0.02em;
		line-height: 1.2;
	}

	.section-text {
		margin: 0 0 1rem;
		color: var(--text-3);
		font-size: 1.0625rem;
		line-height: 1.7;
	}

	.section-text:last-of-type {
		margin-bottom: 1.75rem;
	}

	.link-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 1rem;
		grid-template-columns: 1fr;
	}

	@media (min-width: 480px) {
		.link-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	.latest-grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.8rem;
	}

	@media (min-width: 760px) {
		.latest-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.latest-card {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 1rem;
		border: 1px solid var(--border-1);
		border-radius: var(--radius-md);
		background: var(--surface-1);
		text-decoration: none;
		box-shadow: var(--shadow-sm);
	}

	.latest-card:hover {
		border-color: var(--border-2);
		box-shadow: var(--shadow-md);
	}

	.latest-card-title {
		color: var(--text-1);
		font-weight: 600;
	}

	.latest-card-meta {
		color: var(--text-3);
		font-size: 0.85rem;
	}

	.topic-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.topic-chip {
		display: inline-flex;
		gap: 0.35rem;
		align-items: center;
		padding: 0.35rem 0.65rem;
		border-radius: 999px;
		border: 1px solid var(--border-1);
		background: var(--surface-1);
		color: var(--primary-600);
		text-decoration: none;
		font-size: 0.84rem;
	}

	.topic-chip span {
		color: var(--text-3);
	}

	.tile-link {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 1.25rem 1.35rem;
		background: var(--surface-1);
		border: 1px solid var(--border-1);
		border-radius: var(--radius-md);
		text-decoration: none;
		color: inherit;
		box-shadow: var(--shadow-sm);
		transition:
			transform 0.15s ease,
			border-color 0.15s ease,
			box-shadow 0.15s ease;
	}

	.tile-link:hover {
		border-color: var(--border-2);
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.tile-link-title {
		font-weight: 600;
		font-size: 1.05rem;
		color: var(--text-heading);
	}

	.tile-link-desc {
		font-size: 0.875rem;
		color: var(--text-3);
	}
</style>
