---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';
import SiteSectionRenderer from '../components/sections/SiteSectionRenderer.astro';
import type { PageSection } from '../components/sections/Section.types';

const home = await getEntry('sitePages', 'home');
const { Content } = home ? await render(home) : { Content: null };

const pageTitle = home?.data.pageTitle ?? 'Trang chủ';
const pageDescription =
	home?.data.pageDescription ??
	'Blog và nội dung tĩnh với Astro + Keystatic — giao diện sáng, chuyên nghiệp.';
const heroTitle = home?.data.heroTitle ?? 'Welcome';
const heroLead =
	home?.data.heroLead ??
	'Astroblog = Astro + Keystatic';
const primaryCtaLabel = home?.data.primaryCtaLabel ?? 'Khám phá blog';
const primaryCtaHref = home?.data.primaryCtaHref ?? '/blog';
const secondaryCtaLabel = home?.data.secondaryCtaLabel ?? 'Giới thiệu';
const secondaryCtaHref = home?.data.secondaryCtaHref ?? '/about';
const heroOverlayOpacity = home?.data.heroOverlayOpacity ?? 0.45;
const posts = await getCollection('posts', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const latestPosts = posts.slice(0, 3);
const topicCounts = new Map<string, number>();
for (const post of posts) {
	for (const tag of post.data.tags ?? []) {
		topicCounts.set(tag, (topicCounts.get(tag) ?? 0) + 1);
	}
}
const trendingTopics = [...topicCounts.entries()]
	.sort((a, b) => b[1] - a[1])
	.slice(0, 6);

const isValidSection = (value: unknown): value is PageSection =>
	Boolean(value) &&
	typeof value === 'object' &&
	'type' in value &&
	typeof (value as { type?: unknown }).type === 'string';

const defaultSections: PageSection[] = [
	{
		type: 'hero',
		title: heroTitle,
		lead: heroLead,
		backgroundImage: home?.data.heroBackgroundImage ? { src: home.data.heroBackgroundImage.src } : undefined,
		overlayOpacity: heroOverlayOpacity,
		primaryCtaLabel,
		primaryCtaHref,
		secondaryCtaLabel,
		secondaryCtaHref,
	},
	{
		type: 'services',
		title: 'Our Services',
		lead: 'Dich vu co the duoc chinh sua trong Keystatic de tao landing page nhanh va dong nhat.',
		items: [
			{ title: 'IT Consultant Services', description: 'Tu van he thong va toi uu quy trinh trien khai.' },
			{ title: 'IT Recruitment Services', description: 'Ket noi nhanh doi ngu ky su phu hop du an.' },
			{ title: 'Business Application Services', description: 'Xay dung ung dung ho tro van hanh doanh nghiep.' },
			{ title: 'Sourcing & Staffing Services', description: 'Bo sung nguon luc linh hoat cho team phat trien.' },
		],
	},
	{
		type: 'cta',
		title: 'San sang bat dau du an moi?',
		lead: 'Su dung Keystatic de tao section va cap nhat noi dung ma khong can sua code frontend.',
		primaryCtaLabel: 'Lien he tu van',
		primaryCtaHref: '/contact',
		secondaryCtaLabel: 'Xem blog',
		secondaryCtaHref: '/blog',
	},
];

const cmsSections = Array.isArray(home?.data.sections)
	? home.data.sections.filter(isValidSection)
	: [];
const pageSections = cmsSections.length > 0 ? cmsSections : defaultSections;
---

<Layout
	title={pageTitle}
	description={pageDescription}
	wideMain
>
	<SiteSectionRenderer sections={pageSections} />

	<div class="page-body landing-shell">
		<section class="section panel" aria-labelledby="section-explore">
			{Content ? (
				<article class="prose">
					<Content />
				</article>
			) : (
				<>
					<h2 id="section-explore" class="section-title">Cách làm việc với site này</h2>
					<p class="section-text">
						Nội dung bài viết và trang tĩnh nằm trong repo dưới dạng file Markdoc. Khi phát triển, mở
						Keystatic để thêm hoặc sửa bài.
					</p>
				</>
			)}
			<ul class="link-grid">
				<li>
					<a href="/blog" class="tile-link">
						<span class="tile-link-title">Blog</span>
						<span class="tile-link-desc">Danh sách bài viết mới nhất</span>
					</a>
				</li>
				<li>
					<a href="/keystatic" class="tile-link">
						<span class="tile-link-title">Keystatic</span>
						<span class="tile-link-desc">Chỉnh nội dung khi chạy dev</span>
					</a>
				</li>
			</ul>
		</section>

		{latestPosts.length > 0 && (
			<section class="section panel" aria-labelledby="latest-posts">
				<h2 id="latest-posts" class="section-title">Bài viết mới nhất</h2>
				<ul class="latest-grid">
					{latestPosts.map((post) => (
						<li>
							<a href={`/blog/${post.id}`} class="latest-card">
								<span class="latest-card-title">{post.data.title}</span>
								<span class="latest-card-meta">
									{post.data.category ?? 'Blog'} · {post.data.publishDate.toLocaleDateString('vi-VN')}
								</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		)}

		{trendingTopics.length > 0 && (
			<section class="section panel" aria-labelledby="trending-topics">
				<h2 id="trending-topics" class="section-title">Chủ đề nổi bật</h2>
				<div class="topic-row">
					{trendingTopics.map(([topic, count]) => (
						<a href="/blog" class="topic-chip">
							#{topic} <span>{count}</span>
						</a>
					))}
				</div>
			</section>
		)}
	</div>
</Layout>

<style>
	.page-body {
		background: var(--bg-page);
		padding: 2.5rem 1.25rem 4rem;
	}

	.section {
		max-width: 54rem;
		margin: 0 auto;
	}

	.panel {
		padding: 2rem 0 0;
	}

	.section-title {
		margin: 0 0 1rem;
		font-size: clamp(1.35rem, 3vw, 1.65rem);
		font-weight: 700;
		color: var(--text-heading);
		letter-spacing: -0.02em;
		line-height: 1.2;
	}

	.section-text {
		margin: 0 0 1rem;
		color: var(--text-3);
		font-size: 1.0625rem;
		line-height: 1.7;
	}

	.section-text:last-of-type {
		margin-bottom: 1.75rem;
	}

	.link-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 1rem;
		grid-template-columns: 1fr;
	}

	@media (min-width: 480px) {
		.link-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	.latest-grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.8rem;
	}

	@media (min-width: 760px) {
		.latest-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.latest-card {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 1rem;
		border: 1px solid var(--border-1);
		border-radius: var(--radius-md);
		background: var(--surface-1);
		text-decoration: none;
		box-shadow: var(--shadow-sm);
	}

	.latest-card:hover {
		border-color: var(--border-2);
		box-shadow: var(--shadow-md);
	}

	.latest-card-title {
		color: var(--text-1);
		font-weight: 600;
	}

	.latest-card-meta {
		color: var(--text-3);
		font-size: 0.85rem;
	}

	.topic-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.topic-chip {
		display: inline-flex;
		gap: 0.35rem;
		align-items: center;
		padding: 0.35rem 0.65rem;
		border-radius: 999px;
		border: 1px solid var(--border-1);
		background: var(--surface-1);
		color: var(--primary-600);
		text-decoration: none;
		font-size: 0.84rem;
	}

	.topic-chip span {
		color: var(--text-3);
	}

	.tile-link {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 1.25rem 1.35rem;
		background: var(--surface-1);
		border: 1px solid var(--border-1);
		border-radius: var(--radius-md);
		text-decoration: none;
		color: inherit;
		box-shadow: var(--shadow-sm);
		transition:
			transform 0.15s ease,
			border-color 0.15s ease,
			box-shadow 0.15s ease;
	}

	.tile-link:hover {
		border-color: var(--border-2);
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.tile-link-title {
		font-weight: 600;
		font-size: 1.05rem;
		color: var(--text-heading);
	}

	.tile-link-desc {
		font-size: 0.875rem;
		color: var(--text-3);
	}
</style>
